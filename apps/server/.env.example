OPENAI_API_KEY=your_openai_api_key_here


# Optional model overrides (defaults in code are already set)
# OPENAI_CHAT_MODEL=gpt-4.1
# OPENAI_INTERVENTION_MODEL=gpt-4.1
# OPENAI_CONVERSATION_MODEL=gpt-4.1
# OPENAI_SUMMARY_MODEL=gpt-4.1
# OPENAI_STRESS_SUPPORT_MODEL=gpt-4.1

# Optional fine-tuned / custom model hooks
# THINKING_TRAP_MODEL=ft:gpt-4.1-...:thinking-traps:...
# REFRAME_MODEL=gpt-4.1

# Server port (default 8787)
# PORT=8787

# Comma-separated allowlist for browser origins (recommended in production)
# Example:
# CORS_ORIGINS=https://your-app.example.com,https://www.your-app.example.com
# If empty in production, browser requests with Origin headers are blocked.
# CORS_ORIGINS=

# Session/log read endpoints (GET /sessions, /sessions/export, /sessions/:id)
# Disabled by default in production unless explicitly enabled.
# ALLOW_SESSION_READS=0

# Log SSE stream endpoint (GET /logs/stream)
# Disabled by default in production unless explicitly enabled.
# ALLOW_LOG_STREAM=0

# In-memory per-IP rate limiting for expensive routes
# RATE_LIMIT_ENABLED=1
# RATE_LIMIT_MAX=120
# RATE_LIMIT_WINDOW_MS=60000

# Optional storage overrides
# SUPPORT_DB_PATH=./data/support.db
# DATABASE_URL=postgres://...
